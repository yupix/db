# Database URL for Control DB
DATABASE_URL=postgres://admin:admin123@localhost:5432/dbcontrol

# JWT Secret (change in production!)
JWT_SECRET=dev-super-secret-key-change-me

# Server
HOST=0.0.0.0
PORT=8080

# Logging
RUST_LOG=info,backend=debug

# Host-side directory backup archives are written to (Phase 8)
BACKUP_DIR=./data/backups

# Hostname embedded in connection strings returned to clients
# Change to your server's IP or domain when running on a remote host
PUBLIC_HOST=localhost
